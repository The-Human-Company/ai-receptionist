        "operation": "read",
        "documentId": { "__rl": true, "value": "=1Obobj0x_BmjrnAnSO3DwLkGUd1GXtQvyIIGr4o1PpT8", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Tickets", "mode": "name" },
