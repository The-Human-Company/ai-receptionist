      "id": "wf07-read-escalations",
      "name": "Read Escalation Tracking",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [530, 600],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "Mx6UAeNueCHJeT8c",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Hot lead escalation acknowledgment loop:\n// - If Val hasn't ACK'd within 30 min → escalate to Davin\n// - If Davin hasn't ACK'd within 30 min after that → email both URGENT\nconst now = new Date();\nconst THIRTY_MIN = 30 * 60 * 1000;\n\nconst needsEscalation = [];\n\nfor (const item of items) {\n  const d = item.json;\n  \n  // Skip already acknowledged\n  if (d.acknowledged === 'true' || d.acknowledged === true) continue;\n  \n  const flaggedAt = new Date(d.flagged_at);\n  const elapsed = now - flaggedAt;\n  const escalatedToDavin = (d.escalated_to_davin === 'true' || d.escalated_to_davin === true);\n  \n  if (!escalatedToDavin && elapsed >= THIRTY_MIN) {\n    // Val hasn't ACK'd in 30 min → escalate to Davin\n    needsEscalation.push({\n      json: { ...d, action: 'escalate_to_davin', minutes_waiting: Math.round(elapsed / 60000) }\n    });\n  } else if (escalatedToDavin) {\n    const escalatedAt = new Date(d.escalated_to_davin_at || d.flagged_at);\n    const elapsedSinceEscalation = now - escalatedAt;\n    if (elapsedSinceEscalation >= THIRTY_MIN) {\n      // Davin hasn't ACK'd in 30 min → URGENT email to both\n      needsEscalation.push({\n        json: { ...d, action: 'urgent_both', minutes_waiting: Math.round(elapsed / 60000) }\n      });\n    }\n  }\n}\n\nif (needsEscalation.length === 0) {\n  return [{ json: { no_escalations_needed: true } }];\n}\n\nreturn needsEscalation;"
      },
      "id": "wf07-filter-unacked",
      "name": "Filter Unacknowledged Hot Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 600]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "has-escalations",
              "leftValue": "={{ $json.no_escalations_needed }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "notEquals", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "wf07-if-has-escalations",
      "name": "IF Has Escalations",
      "type": "n8n-nodes-base.if",
