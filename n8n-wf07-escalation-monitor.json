    {
      "parameters": {
        "jsCode": "// Handle incoming SMS replies (ACK acknowledgments)\n// Twilio sends inbound SMS to this webhook\nconst body = $input.first().json.body || $input.first().json;\nconst from = (body.From || '').replace(/[\\s\\-\\(\\)]/g, '');\nconst messageBody = (body.Body || '').trim().toUpperCase();\n\nif (messageBody.includes('ACK')) {\n  // Determine who acknowledged\n  let acknowledgedBy = 'unknown';\n  if (from.includes('8087800473')) {\n    acknowledgedBy = 'val';\n  } else {\n    acknowledgedBy = 'davin';\n  }\n  \n  return [{ json: { acknowledged: true, acknowledged_by: acknowledgedBy, from: from } }];\n}\n\nreturn [{ json: { acknowledged: false, from: from, message: messageBody } }];"
      },
      "id": "wf07-parse-ack",
      "name": "Parse ACK Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [530, 900]
    },
