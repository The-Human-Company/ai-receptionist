      "id": "wf07-read-tickets",
      "name": "Read Pending Tickets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [530, 200],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "Mx6UAeNueCHJeT8c",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const tickets = items;\nconst now = new Date();\nconst thresholdMs = 2 * 60 * 60 * 1000; // 2 hours\n\nconst overdue = tickets.filter(t => {\n  const created = new Date(t.json.created_at);\n  return (now - created) >= thresholdMs && t.json.status === 'pending';\n});\n\nreturn overdue.length > 0 ? overdue : [];"
      },
      "id": "wf07-filter-overdue",
      "name": "Filter Overdue Tickets",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 200]
    },
    {
